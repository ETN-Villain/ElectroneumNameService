# ── Chain connection ──────────────────────────────────────────────────────────
RPC_URL=https://rpc.ankr.com/electroneum
REGISTRAR_ADDRESS=0x553B1D45CeE1111CE2940c76C23bFC1B70Ed37e3

# ── Backend signer wallet ──────────────────────────────────────────────────────
# This wallet must be set as imageOperator on the registrar contract
# (call registrar.setImageOperator(thisWalletAddress) from your owner wallet)
BACKEND_PRIVATE_KEY=f7ae9097ed86f10c0511a47b4addd371b9e0d448a57b191d4b6b36e2d184a3c5

# ── Image generation ───────────────────────────────────────────────────────────
# Path to your stock/template image (PNG), relative to project root
STOCK_IMAGE_PATH=./assets/stock-template.png

# Font size and color for the name text overlay
FONT_SIZE=64
FONT_COLOR=#ffffff
FONT_FAMILY=sans-serif

# Text position as a percentage of image width/height (0.5 = center)
TEXT_X_PERCENT=0.5
TEXT_Y_PERCENT=0.85

# ── Storage upload ──────────────────────────────────────────────────────────────
# Choose one storage backend: "local" (serves from this same server),
# "s3" (AWS S3 or S3-compatible like Cloudflare R2/Backblaze B2)
STORAGE_TYPE=local

# Only needed if STORAGE_TYPE=local — public base URL where this server's
# /images route is reachable (e.g. your Render service URL)
LOCAL_BASE_URL=https://your-render-service.onrender.com

# Only needed if STORAGE_TYPE=s3
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_PUBLIC_BASE_URL=

# ── Server ──────────────────────────────────────────────────────────────────────
PORT=3000

# Secret required in the X-Admin-Secret header to call POST /regenerate/:node
ADMIN_SECRET=choose_a_long_random_string_here

# ── Event listener behavior ─────────────────────────────────────────────────────
# How many past blocks to scan on startup IF no persisted state exists yet
# (first-ever run, or if data/state.json was lost — e.g. Render redeploy
# without a persistent disk attached)
STARTUP_LOOKBACK_BLOCKS=50000

# How often to poll for new events, in milliseconds
POLL_INTERVAL_MS=15000

# Max blocks per eth_getLogs query — keeps individual RPC calls small even
# when catching up a large range, since many providers cap this
MAX_BLOCK_RANGE_PER_QUERY=5000

